# Vertex AI (bills to your GCP project / $300 trial credits)
# Do NOT use OAuth client_secret JSON — create a Service Account instead.
#
# 1. console.cloud.google.com → IAM → Service Accounts → Create
# 2. Role: Vertex AI User (roles/aiplatform.user)
# 3. Keys → Add key → JSON → download
# 4. APIs & Services → Enable "Vertex AI API"
#
# Local backend/.env:
GEMINI_AUTH_MODE=vertex
GCP_PROJECT_ID=project-f866d112-848c-47a5-bf7
GCP_LOCATION=us-central1
GCP_SERVICE_ACCOUNT_PATH=C:/path/to/your-service-account.json
GEMINI_VERTEX_MODEL=gemini-2.0-flash
#
# Render (paste the entire JSON file as ONE line, or use Render Secret File):
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
# GEMINI_AUTH_MODE=vertex
# GCP_PROJECT_ID=project-f866d112-848c-47a5-bf7
# GCP_LOCATION=us-central1
#
# Leave GEMINI_API_KEY unset when using Vertex, or keep it as fallback with GEMINI_AUTH_MODE=api_key

# Parts search (Google Shopping via Serper — required for real parts, not mock data)
# SERPER_API_KEY=your_key_from_serper.dev
